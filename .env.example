# ===========================================
# Relatos de Papel - Variables de Entorno
# ===========================================

# --- Frontend ---
REACT_APP_API_BASE_URL=http://localhost:8090

# --- URLs base de los servicios ---
BASE_URL_GATEWAY=http://localhost:8090
BASE_URL_CATALOGUE=http://localhost:8081
BASE_URL_PAYMENTS=http://localhost:8082
BASE_URL_SEARCH=http://localhost:8083
BASE_URL_EUREKA=http://localhost:8761

# --- Elasticsearch ---
ELASTICSEARCH_URI=http://localhost:9200

# --- Swagger UI ---
SWAGGER_UI_URL=http://localhost:8081/swagger-ui/index.html
SWAGGER_SEARCH_URL=http://localhost:8083/swagger-ui/index.html

# --- Rutas de API ---
BOOKS_PATH=/libros
PEDIDOS_PATH=/pedidos
SEARCH_PATH=/search

# --- k6 - Parámetros de carga ---
K6_VUS=10
K6_DURATION=30s

# --- Newman ---
NEWMAN_REPORTERS=cli,htmlextra

