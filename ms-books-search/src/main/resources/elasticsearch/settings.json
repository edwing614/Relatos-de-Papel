{
  "index": {
    "number_of_shards": 1,
    "number_of_replicas": 0
  },
  "analysis": {
    "analyzer": {
      "spanish_analyzer": {
        "type": "custom",
        "tokenizer": "standard",
        "filter": ["lowercase", "asciifolding", "spanish_stop", "spanish_stemmer"]
      }
    },
    "filter": {
      "spanish_stop": {
        "type": "stop",
        "stopwords": "_spanish_"
      },
      "spanish_stemmer": {
        "type": "stemmer",
        "language": "spanish"
      }
    }
  }
}
